generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL") // pooled (-pooler) endpoint — serverless-safe
  directUrl = env("DIRECT_URL")   // direct endpoint — used for migrations only
}

model CourseOperator {
  id                  String    @id @default(cuid())
  email               String    @unique
  password            String
  name                String
  emailVerified       Boolean   @default(false)
  verificationToken   String?
  resetToken          String?   @unique
  resetTokenExpiry    DateTime?
  onboardingStep      Int       @default(0)
  failedLoginAttempts Int       @default(0)
  lockoutUntil        DateTime?
  twoFactorEnabled    Boolean   @default(false)
  twoFactorMethod     String    @default("email")
  twoFactorCode       String?
  twoFactorCodeExpiry DateTime?
  phone               String    @default("")
  createdAt           DateTime  @default(now())
  course              Course?
}

model Course {
  id                    String             @id @default(cuid())
  slug                  String             @unique
  name                  String
  type                  String             @default("public")
  city                  String             @default("")
  state                 String             @default("")
  zipCode               String             @default("")
  address               String             @default("")
  phone                 String             @default("")
  website               String             @default("")
  bookingUrl            String             @default("")
  holes                 Int                @default(18)
  par                   Int                @default(72)
  yardage               Int                @default(0)
  slope                 Int                @default(0)
  courseRating          Float              @default(0)
  description           String             @default("")
  amenities             String[]
  walkingAllowed        String             @default("always")
  walkingNote           String             @default("")
  cartRequired          Boolean            @default(false)
  dresscode             String[]
  minPlayers            Int                @default(1)
  maxPlayers            Int                @default(4)
  cancellationHours     Int                @default(24)
  lateCancellationFee   Float              @default(10)
  timezone              String             @default("America/New_York")
  rainCheckPolicy       String             @default("")
  publicAdvanceDays     Int                @default(7)
  memberAdvanceDays     Int                @default(14)
  hasMemberPricing      Boolean            @default(false)
  hasResidentPricing    Boolean            @default(false)
  residentCounty        String             @default("")
  residentState         String             @default("")
  residentProofRequired Boolean            @default(false)
  hasCaddies            Boolean            @default(false)
  caddieType            String             @default("")
  caddieLooperRate      Float              @default(0)
  caddieForeRate        Float              @default(0)
  caddieNote            String             @default("")
  hasDrivingRange       Boolean            @default(false)
  drivingRangeType      String             @default("")
  rangeBallsFree        Boolean            @default(true)
  rangeBallsSmallPrice  Float              @default(0)
  rangeBallsMediumPrice Float              @default(0)
  rangeBallsLargePrice  Float              @default(0)
  hasPuttingGreen       Boolean            @default(false)
  hasShortGameArea      Boolean            @default(false)
  hasProShop            Boolean            @default(false)
  proShopPhone          String             @default("")
  restaurantType        String             @default("none")
  hasCartGirl           Boolean            @default(false)
  tournamentFrequency   String             @default("")
  hasLessons            Boolean            @default(false)
  hasClubRental         Boolean            @default(false)
  clubRentalRate        Float              @default(0)
  hasPushCartRental     Boolean            @default(false)
  pushCartRate          Float              @default(0)
  hasBagStorage         Boolean            @default(false)
  hasLockerRoom         Boolean            @default(false)
  hasGpsCarts           Boolean            @default(false)
  hasTournaments        Boolean            @default(false)
  stripeAccountId       String             @default("")
  stripeAccountActive   Boolean            @default(false)
  rating                Float              @default(4.5)
  reviewCount           Int                @default(0)
  imageGradient         String             @default("linear-gradient(160deg,#071810 0%,#1b4332 60%,#2d6a4f 100%)")
  logoUrl               String             @default("")
  heroImageUrl          String             @default("")
  featured              Boolean            @default(false)
  active                Boolean            @default(false)
  liveStatus            String             @default("draft")
  adminNotes            String             @default("")
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt
  operatorId            String?            @unique
  operator              CourseOperator?    @relation(fields: [operatorId], references: [id])
  conditions            String             @default("")
  conditionsUpdatedAt   DateTime?
  teeTimes              TeeTime[]
  bookings              Booking[]
  schedules             TeeTimeSchedule[]
  blackouts             Blackout[]
  memberships           CourseMembership[]
  membershipTiers       MembershipTier[]
  waitlist              Waitlist[]
  staff                 CourseStaff[]
  teeSets               TeeSet[]
}

// A single tee box (Black/Blue/White/Red/Gold...) — courses with one set of
// markers just have one row here; courses with multiple tee options list them
// all so golfers/admin can see yardage/rating/slope per tee, not one flat number.
model TeeSet {
  id        String   @id @default(cuid())
  courseId  String
  course    Course   @relation(fields: [courseId], references: [id])
  name      String
  yardage   Int      @default(0)
  rating    Float    @default(0)
  slope     Int      @default(0)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
}

model CourseStaff {
  id                  String    @id @default(cuid())
  courseId            String
  course              Course    @relation(fields: [courseId], references: [id])
  email               String    @unique
  password            String
  name                String
  role                String    @default("staff")
  active              Boolean   @default(true)
  failedLoginAttempts Int       @default(0)
  lockoutUntil        DateTime?
  createdAt           DateTime  @default(now())
}

model GolferAccount {
  id                  String             @id @default(cuid())
  email               String             @unique
  password            String
  firstName           String
  lastName            String
  phone               String             @default("")
  stripeCustomerId    String             @default("")
  resetToken          String?            @unique
  resetTokenExpiry    DateTime?
  failedLoginAttempts Int                @default(0)
  lockoutUntil        DateTime?
  createdAt           DateTime           @default(now())
  bookings            Booking[]
  memberships         CourseMembership[]
  waitlist            Waitlist[]
}

model MembershipTier {
  id                 String             @id @default(cuid())
  courseId           String
  course             Course             @relation(fields: [courseId], references: [id])
  name               String // "Full Member", "Junior", "Senior Associate"
  color              String             @default("#1b4332")
  // Pricing — flat rate overrides. null = fall back to discountPct or standard rate
  greenFeeWeekday    Float?
  greenFeeWeekend    Float?
  cartFeeWeekday     Float?
  cartFeeWeekend     Float?
  // Alternative: percentage off the standard rate (0–100)
  discountPct        Float?
  // Access privileges
  advanceBookingDays Int                @default(14)
  guestPassesPerYear Int                @default(0)
  // Informational
  annualFee          Float              @default(0)
  initiationFee      Float              @default(0) // one-time, charged with the first dues payment
  termMonths         Int                @default(12)
  notes              String             @default("")
  active             Boolean            @default(true)
  createdAt          DateTime           @default(now())
  memberships        CourseMembership[]
}

model CourseMembership {
  id             String          @id @default(cuid())
  golferId       String?
  golfer         GolferAccount?  @relation(fields: [golferId], references: [id])
  courseId       String
  course         Course          @relation(fields: [courseId], references: [id])
  tierId         String?
  tier           MembershipTier? @relation(fields: [tierId], references: [id])
  // Fallback name when no tier selected, or for non-golfer-account members
  membershipType String          @default("member")
  // For members without a GolferAccount — invite flow
  inviteEmail    String          @default("")
  inviteName     String          @default("")
  invitePhone    String          @default("")
  inviteAccepted Boolean         @default(false)
  status         String          @default("active")
  addedBy        String          @default("operator")
  expiresAt      DateTime?
  startedAt      DateTime?
  // Dues: unpaid | paid | paid_offline (cash/check at the shop) | comped
  paymentStatus  String          @default("unpaid")
  payToken       String          @default("")
  lastPaidAt     DateTime?
  lastPaymentIntentId String     @default("")
  renewalRemindedAt   DateTime?
  notes          String          @default("")
  createdAt      DateTime        @default(now())

  @@unique([golferId, courseId])
}

model TeeTime {
  id               String     @id @default(cuid())
  courseId         String
  course           Course     @relation(fields: [courseId], references: [id])
  date             String
  time             String
  holes            Int        @default(18)
  playersAvailable Int        @default(4)
  playersBooked    Int        @default(0)
  greenFee         Float
  memberRate       Float?
  residentRate     Float?
  cartFee          Float      @default(0)
  walkingAllowed   Boolean    @default(true)
  tierName         String     @default("standard")
  status           String     @default("available")
  createdAt        DateTime   @default(now())
  bookings         Booking[]
  waitlist         Waitlist[]

  @@index([courseId, date])
}

model Booking {
  id                       String         @id @default(cuid())
  teeTimeId                String
  teeTime                  TeeTime        @relation(fields: [teeTimeId], references: [id])
  courseId                 String
  course                   Course         @relation(fields: [courseId], references: [id])
  golferAccountId          String?
  golferAccount            GolferAccount? @relation(fields: [golferAccountId], references: [id])
  golferName               String
  golferEmail              String
  golferPhone              String         @default("")
  players                  Int
  appliedRate              String         @default("standard")
  greenFeeTotal            Float
  cartFeeTotal             Float          @default(0)
  cartSelected             Boolean        @default(false)
  rangeBallsSize           String         @default("")
  rangeBallsTotal          Float          @default(0)
  accessFeeTotal           Float
  totalAmount              Float
  // Card-on-file, deferred-payment flow — nothing is charged at booking time.
  stripeCustomerId         String         @default("")
  stripePaymentMethodId    String         @default("")
  stripePaymentIntentId    String         @default("")
  cancellationFeeTotal     Float          @default(0)
  cancellationFeeChargeId  String         @default("")
  cancellationFeeChargedAt DateTime?
  cancelledAt              DateTime?
  // Check-in / round-charge flow (Phase 2) — direct charge on the course's
  // connected Stripe account, refunding the cancellation fee above if one was
  // already taken. checkInToken lets a golfer check in from the reminder
  // email on a fresh device without needing to be logged in.
  checkInToken             String?        @unique // generated explicitly in app code at booking creation, not a DB default —
  // existing rows added before this column existed will be null and just won't have a self-checkin link (staff can still check them in manually)
  checkedInAt              DateTime?
  roundPaymentIntentId     String         @default("")
  checkInFailReason        String         @default("")
  paymentStatus            String         @default("card_on_file")
  status                   String         @default("confirmed")
  createdAt                DateTime       @default(now())
}

model TeeTimeSchedule {
  id                  String   @id @default(cuid())
  courseId            String
  course              Course   @relation(fields: [courseId], references: [id])
  tierName            String   @default("standard")
  daysOfWeek          Int[]
  startTime           String
  endTime             String
  intervalMinutes     Int      @default(8)
  holes               Int      @default(18)
  greenFeeWeekday     Float
  greenFeeWeekend     Float
  memberRateWeekday   Float?
  memberRateWeekend   Float?
  residentRateWeekday Float?
  residentRateWeekend Float?
  cartFee             Float    @default(0)
  walkingAllowed      Boolean  @default(true)
  active              Boolean  @default(true)
  createdAt           DateTime @default(now())
}

model Blackout {
  id       String @id @default(cuid())
  courseId String
  course   Course @relation(fields: [courseId], references: [id])
  date     String
  reason   String @default("")
}

model Waitlist {
  id        String         @id @default(cuid())
  teeTimeId String
  teeTime   TeeTime        @relation(fields: [teeTimeId], references: [id])
  courseId  String
  course    Course         @relation(fields: [courseId], references: [id])
  golferId  String?
  golfer    GolferAccount? @relation(fields: [golferId], references: [id])
  name      String
  email     String
  phone     String         @default("")
  players   Int            @default(1)
  notified  Boolean        @default(false)
  createdAt DateTime       @default(now())
}

model CourseInquiry {
  id                   String   @id @default(cuid())
  firstName            String   @default("")
  lastName             String   @default("")
  contactName          String
  contactTitle         String
  email                String
  phone                String
  courseName           String
  address              String
  city                 String
  state                String
  zipCode              String
  website              String   @default("")
  courseType           String
  currentBookingMethod String   @default("")
  teeTimesPerDay       Int?
  greenFeeRange        String   @default("")
  hasResidentPricing   Boolean  @default(false)
  hasMemberPricing     Boolean  @default(false)
  hasCaddies           Boolean  @default(false)
  pricingNotes         String   @default("")
  facilitiesNotes      String   @default("")
  lookingFor           String[]
  additionalNotes      String   @default("")
  needsJson            String   @default("")
  status               String   @default("pending")
  adminNotes           String   @default("")
  builtCourseId        String?
  detailsToken         String?  @unique
  detailsJson          String   @default("")
  reviewStartedAt      DateTime?
  wentLiveAt           DateTime?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  events               InquiryStatusEvent[]
}

model InquiryStatusEvent {
  id         String        @id @default(cuid())
  inquiryId  String
  fromStatus String
  toStatus   String
  trigger    String        // 'system' | 'admin'
  actorName  String?
  createdAt  DateTime      @default(now())
  inquiry    CourseInquiry @relation(fields: [inquiryId], references: [id], onDelete: Cascade)
}

// Per-IP fixed-window rate limiting (shared across serverless instances)
model RateLimit {
  key         String   @id
  count       Int      @default(1)
  windowStart DateTime @default(now())
}

model AdminUser {
  id                     String    @id @default(cuid())
  email                  String    @unique
  name                   String
  passwordHash           String
  role                   String    @default("staff")  // "owner" | "staff"
  active                 Boolean   @default(true)
  lastLoginAt            DateTime?
  createdAt              DateTime  @default(now())
  setPasswordToken       String?   @unique
  setPasswordTokenExpiry DateTime?
}

model Announcement {
  id         String                  @id @default(cuid())
  title      String
  body       String
  emailSent  Boolean                 @default(false)
  sentById   String
  createdAt  DateTime                @default(now())
  dismissals AnnouncementDismissal[]
}

model AnnouncementDismissal {
  id             String       @id @default(cuid())
  announcementId String
  operatorId     String
  createdAt      DateTime     @default(now())
  announcement   Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)

  @@unique([announcementId, operatorId])
}
