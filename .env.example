# ============================================================
# GreenReserve — environment variable map (NO VALUES, safe to commit)
#
# Where the real values live:
#   - App secrets  → Vercel: dashboard.vercel.com → green-reserve → Settings → Env Vars
#   - Human logins → KeePassXC (Neon console, Stripe, GitHub, admin password)
#
# Rebuild your local file anytime:   vercel env pull .env.local
# Full inventory + rotation steps:   docs/RUNBOOK.md
# ============================================================

# --- Database (Neon) — regenerate: Neon console → Connection Details ---
DATABASE_URL=            # pooled URL, keep &pgbouncer=true&connect_timeout=15
DIRECT_URL=              # direct URL (migrations)
SHADOW_DATABASE_URL=     # Neon shadow-dev branch — needed by `prisma migrate dev` (local only)

# --- Auth / sessions — regenerate: openssl rand -hex 32 ---
JWT_SECRET=
NEXTAUTH_SECRET=         # legacy alias, same value as JWT_SECRET
ADMIN_TOKEN=             # bootstrap admin creation

# --- Stripe — Stripe dashboard → Developers ---
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=   # Webhooks → endpoint → signing secret

# --- Email (Resend) — resend.com → API Keys ---
RESEND_API_KEY=

# --- SMS 2FA (Twilio) — twilio.com → Console ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# --- App ---
NEXT_PUBLIC_URL=https://greenreserve.app
CRON_SECRET=             # openssl rand -hex 32 — authenticates Vercel cron

# --- Monitoring (Sentry) — greenreserve.sentry.io → project settings ---
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=  # same DSN
SENTRY_ORG=greenreserve
SENTRY_PROJECT=javascript-nextjs

# --- File uploads (Vercel Blob) ---
BLOB_READ_WRITE_TOKEN=
